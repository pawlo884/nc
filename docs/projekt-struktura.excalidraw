    {
      "id": "hUNijpSUckBPH5CIqEjdj",
      "type": "text",
      "x": 517.9756038167593,
      "y": 298.23939050258946,
      "width": 897.1032104492188,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aK",
      "roundness": null,
      "seed": 911678247,
      "version": 716,
      "versionNonce": 946494247,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1766944565266,
      "link": null,
      "locked": false,
      "text": "Dodawanie do głównej bazy produktów z baz hurtowni, zmiana opisów, unifikacja, obróbka według własnego uznania\n(jeśli produkty się powielają to jedynie je mapujemy po kodzie EAN lub rozmiarze, itp..)\nWprowadzona została automatyzacja. Można dodawać produkty automatycznie. \nAI ulepsza opis, wyciąga z opisu atrybuty i je dodaje.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Dodawanie do głównej bazy produktów z baz hurtowni, zmiana opisów, unifikacja, obróbka według własnego uznania\n(jeśli produkty się powielają to jedynie je mapujemy po kodzie EAN lub rozmiarze, itp..)\nWprowadzona została automatyzacja. Można dodawać produkty automatycznie. \nAI ulepsza opis, wyciąga z opisu atrybuty i je dodaje.",
      "autoResize": true,
      "lineHeight": 1.25
    },
