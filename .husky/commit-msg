#!/usr/bin/env sh

# Nie uruchamiaj commitlint w CI (semantic-release tworzy commity)
if [ -n "$CI" ]; then
  exit 0
fi

# Nie blokuj commitów, jeśli Husky nie przekazał ścieżki (np. Windows Git Bash)
if [ -z "$1" ]; then
  echo "commit-msg: brak ścieżki pliku commita – pomijam commitlint"
  exit 0
fi

# Użyj separatora --, żeby przekazać --edit do commitlint,
# a nie do npm (inaczej pojawia się błąd „input is required”)
npx --no commitlint -- --edit "$1"
